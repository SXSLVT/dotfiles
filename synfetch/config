# Set THEME to "custom" to use the hex colors below
THEME="custom"

# Show/Hide modules
SHOW_OS=true
SHOW_KERNEL=true
SHOW_USER=true
SHOW_HOST=true
SHOW_MOBO=true
SHOW_CPU=true
SHOW_GPU=true
SHOW_UPTIME=true
SHOW_SHELL=true
SHOW_DEWM=true
SHOW_PKGS=true
SHOW_USAGE_BARS=true

# Custom hex colors 
