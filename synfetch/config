OS_HEX="#ffbb77"            # OS
KERNEL_HEX="#ffbb77"        # Kernel
USER_HEX="#ffbb77"          # User
HOST_HEX="#ffbb77"          # Hostname
MOBO_HEX="#ffbb77"          # Motherboard
CPU_HEX="#ffbb77"           # CPU
GPU_HEX="#ffbb77"           # GPU
UPTIME_HEX="#ffbb77"        # Uptime
SHELL_HEX="#ffbb77"         # Shell
DEWM_HEX="#ffbb77"          # DE/WM
PKGS_HEX="#ffbb77"          # Packages
BAR_LABEL_HEX="#ffbb77"     # Bar label
